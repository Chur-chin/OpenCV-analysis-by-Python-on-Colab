import numpy as np
import matplotlib.pyplot as plt
from scipy.ndimage import gaussian_filter

def simulate_moire(cell_positions, grating):
    h, w = grating.shape
    moire = np.zeros((h, w))
    
    for cy, cx in cell_positions:
        # Simple cell model (circle with internal texture)
        y, x = np.mgrid[0:h, 0:w]
        r = np.sqrt((y-cy)**2 + (x-cx)**2)
        cell = np.exp(-(r-25)**2 / (2*15**2))  # Gaussian cell
        moire += cell * grating
    
    moire = gaussian_filter(moire, sigma=2)
    return moire

